{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "execution_plan.schema.json",
  "title": "Execution Plan",
  "description": "Claude가 생성하고 사내 실행 엔진이 순차 실행하는 작업 계획서",
  "type": "object",
  "required": ["task_id", "description", "created_by", "created_at", "inputs", "steps", "final_output"],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "작업 식별자 (snake_case)"
    },
    "description": {
      "type": "string",
      "description": "작업에 대한 한 줄 설명"
    },
    "created_by": {
      "type": "string",
      "const": "Claude"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "생성 시각 (ISO 8601)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "default": "1.0.0",
      "description": "plan 버전"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "task_type": {
          "type": "string",
          "description": "작업 유형 분류 (defect_rate, production_report 등)"
        },
        "template_hash": {
          "type": "string",
          "description": "양식 파일의 SHA256 해시 (캐싱 키)"
        },
        "reusable": {
          "type": "boolean",
          "default": true,
          "description": "동일 양식/프로세스에 대해 재사용 가능 여부"
        }
      }
    },
    "inputs": {
      "type": "object",
      "description": "입력 파일/데이터 정의",
      "additionalProperties": {
        "$ref": "#/$defs/input_spec"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "final_output": {
      "$ref": "#/$defs/final_output"
    }
  },
  "$defs": {
    "input_spec": {
      "type": "object",
      "required": ["description", "expected_format"],
      "properties": {
        "description": { "type": "string" },
        "expected_format": {
          "type": "string",
          "enum": ["xlsx", "xls", "csv", "json", "txt"]
        },
        "expected_sheets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "expected_columns": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "step": {
      "type": "object",
      "required": ["step", "action", "description", "params"],
      "properties": {
        "step": {
          "type": "integer",
          "minimum": 1,
          "description": "step 번호 (1부터 시작, 순차)"
        },
        "action": {
          "type": "string",
          "enum": [
            "OPEN_FILE",
            "READ_COLUMNS",
            "READ_RANGE",
            "WRITE_DATA",
            "CLEAR_RANGE",
            "RECALCULATE",
            "FIND_DATE_COLUMN",
            "COPY_RANGE",
            "AGGREGATE_RANGE",
            "SAVE_FILE",
            "VALIDATE",
            "FORMAT_MESSAGE",
            "SEND_MESSENGER",
            "SEND_EMAIL",
            "GENERATE_PPT",
            "LOG"
          ],
          "description": "실행할 ACTION 타입"
        },
        "description": {
          "type": "string",
          "description": "이 step이 하는 일에 대한 설명"
        },
        "params": {
          "type": "object",
          "description": "ACTION별 파라미터 (ACTION 타입에 따라 구조가 다름)"
        },
        "expect": {
          "type": "object",
          "description": "성공 기준 (선택)",
          "properties": {
            "condition": { "type": "string" },
            "value": {}
          }
        },
        "on_fail": {
          "type": "string",
          "enum": ["STOP", "SKIP", "RETRY", "WARN_AND_CONTINUE"],
          "default": "STOP",
          "description": "실패 시 행동"
        },
        "store_as": {
          "type": "string",
          "description": "결과를 저장할 변수명 (다음 step에서 참조 가능)"
        },
        "require_confirm": {
          "type": "boolean",
          "default": false,
          "description": "사용자 확인이 필요한 step 여부 (외부 발송, 파일 덮어쓰기 등)"
        }
      }
    },
    "final_output": {
      "type": "object",
      "required": ["type", "description"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["messenger", "email", "file", "ppt", "multiple"],
          "description": "최종 산출물 유형"
        },
        "description": {
          "type": "string",
          "description": "최종 산출물 설명"
        }
      }
    }
  }
}
